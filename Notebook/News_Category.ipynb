    "# (Replaces your original cell 20)\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from sklearn.utils.class_weight import compute_class_weight\n",
    "\n",
    "# Step 1: Encode text labels to integers\n",
    "label_encoder = LabelEncoder()\n",
    "df['label_encoded'] = label_encoder.fit_transform(df['category'])\n",
    "\n",
    "# Step 2: Split your dataset using the cleaned, combined text\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    df['cleaned_text'],  # **FIX:** Use the new cleaned text column\n",
    "    df['label_encoded'],\n",
    "    test_size=0.2,\n",
    "    stratify=df['label_encoded'],  # keeps class distribution\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "# Step 3: Compute class weights using the correct training labels\n",
    "class_weights = compute_class_weight(\n",
    "    class_weight='balanced',\n",
    "    classes=np.unique(y_train),\n",
    "    y=y_train\n",
    ")\n",
    "class_weights_dict = dict(enumerate(class_weights))"
   ]
  },
