    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import Embedding, Conv1D, GlobalMaxPooling1D, Dense, Dropout\n",
    "from tensorflow.keras.callbacks import EarlyStopping\n",
    "\n",
    "# --- A More Powerful CNN-based Model Architecture ---\n",
    "# This architecture is often much better for text classification\n",
    "model = Sequential()\n",
    "model.add(Embedding(input_dim=10000, output_dim=128, input_length=max_len))\n",
    "model.add(Dropout(0.2)) # Dropout after embedding\n",
    "\n",
    "# Add a 1D Convolutional layer to find patterns (like n-grams)\n",
    "model.add(Conv1D(128, 5, activation='relu'))\n",
    "model.add(GlobalMaxPooling1D()) # Pool the most important features\n",
    "\n",
    "model.add(Dropout(0.5)) # Another dropout layer for regularization\n",
    "model.add(Dense(num_classes, activation='softmax'))\n",
    "\n",
    "# --- Compile the model ---\n",
    "model.compile(loss='categorical_crossentropy', optimizer='adam', metrics=['accuracy'])\n",
    "\n",
    "# --- Add Early Stopping ---\n",
    "# This will stop training if the validation loss doesn't improve for 3 epochs\n",
    "early_stopping = EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)\n",
    "\n",
    "# --- Fit the model (More epochs, NO class_weight for now) ---\n",
    "print(\"Starting model training with a better architecture...\")\n",
    "history = model.fit(\n",
    "    X_train_pad,\n",
    "    y_train_onehot,\n",
    "    epochs=20,  # Increased epochs\n",
    "    batch_size=64, # Slightly larger batch size can help\n",
    "    validation_data=(X_test_pad, y_test_onehot),\n",
    "    callbacks=[early_stopping] # Add the callback here\n",
    ")\n",
    "\n",
    "print(\"\\nTraining complete.\")"
   ]
  },
